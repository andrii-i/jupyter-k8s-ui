# Web UI Backend Environment Configuration
#
# Quick setup: run `make refresh-token` to populate DEV_ACCESS_TOKEN automatically.
# See README.md for prerequisites (kubeconfig + kubectl-oidc-login plugin).

# Development Authentication
# Set automatically by `make refresh-token`. Tokens expire — re-run if you get 401s.
DEV_ACCESS_TOKEN=

# Server Configuration
PORT=8090
NODE_ENV=development

# Kubernetes Configuration
NAMESPACE=default
STATIC_DIR=./dist

# Optional: Override the username extracted from the JWT token
# Format: "github:username" or "email:user@example.com"
# Leave empty to use the username from the token
DEV_USER=
